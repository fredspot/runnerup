<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:runnerup="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
                    android:id="@+id/tab_main"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:layout_margin="@dimen/activity_margin">

                    <org.runnerup.ui.common.widget.TitleSpinner
                        android:id="@+id/summary_sport"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1px"
                        android:prompt="@string/Type"
                        android:text="@string/Sport"
                        android:visibility="gone" />

		    <org.runnerup.ui.common.widget.TitleSpinner
			android:id="@+id/summary_manual_distance"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:minWidth="48dp"
			android:minHeight="48dp"
			android:prompt="@string/Type"
			android:inputType="numberDecimal"
			android:text="@string/Distance"
			runnerup:type="distancepicker" />

                            <LinearLayout
                                android:id="@+id/injury_row"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginTop="8dp">

                                <Button
                                    android:id="@+id/injury_button"
                                    style="@style/ButtonText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/btn_outline_white"
                                    android:textAllCaps="false"
                                    android:textColor="@android:color/white"
                                    android:text="@string/injury"
                                    android:visibility="gone"/>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="horizontal"
                                    android:gravity="end"
                                    android:layout_marginStart="12dp">

                                    <LinearLayout
                                        android:id="@+id/injury_card_before"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical"
                                        android:background="@drawable/ripple_card"
                                        android:padding="8dp"
                                        android:layout_marginEnd="8dp"
                                        android:clickable="true"
                                        android:focusable="true"
                                        android:defaultFocusHighlightEnabled="false">
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="@string/injury_before"
                                            android:textColor="@color/colorTextSecondary"
                                            android:textSize="12sp"/>
                                        <LinearLayout
                                            android:id="@+id/injury_icons_before"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:orientation="horizontal"
                                            android:gravity="start"/>
                                    </LinearLayout>

                                    <LinearLayout
                                        android:id="@+id/injury_card_during"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical"
                                        android:background="@drawable/ripple_card"
                                        android:padding="8dp"
                                        android:layout_marginEnd="8dp"
                                        android:clickable="true"
                                        android:focusable="true"
                                        android:defaultFocusHighlightEnabled="false">
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="@string/injury_during"
                                            android:textColor="@color/colorTextSecondary"
                                            android:textSize="12sp"/>
                                        <LinearLayout
                                            android:id="@+id/injury_icons_during"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:orientation="horizontal"
                                            android:gravity="start"/>
                                    </LinearLayout>

                                    <LinearLayout
                                        android:id="@+id/injury_card_after"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical"
                                        android:background="@drawable/ripple_card"
                                        android:padding="8dp"
                                        android:clickable="true"
                                        android:focusable="true"
                                        android:defaultFocusHighlightEnabled="false">
                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="@string/injury_after"
                                            android:textColor="@color/colorTextSecondary"
                                            android:textSize="12sp"/>
                                        <LinearLayout
                                            android:id="@+id/injury_icons_after"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:orientation="horizontal"
                                            android:gravity="start"/>
                                    </LinearLayout>
                                </LinearLayout>
                            </LinearLayout>

                    <EditText
                        android:id="@+id/notes_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top|left"
                        android:hint="@string/Notes_about_your_workout"
                        android:inputType="textCapSentences|textMultiLine"
                        android:minLines="4"
                        android:singleLine="false"
                        tools:ignore="AutoFill" />

                    <LinearLayout
                        android:id="@+id/hrzonesBarLayout"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="16dp"
                        android:layout_marginStart="0dp"
                        android:layout_marginEnd="0dp"
                        android:background="@android:color/transparent"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:visibility="gone" />
                </LinearLayout>
