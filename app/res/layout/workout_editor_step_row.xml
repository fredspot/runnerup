<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/workout_editor_row_host"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/drag_handle"
        android:layout_width="44dp"
        android:layout_height="52dp"
        android:clickable="true"
        android:contentDescription="@string/Reorder_step"
        android:focusable="false"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        android:scaleType="center"
        android:src="@drawable/ic_drag_handle_24dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/workout_editor_row_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="@string/Repeat_block"
            android:textAppearance="@style/ListCategoryHeading"
            android:textColor="@color/colorText"
            android:visibility="gone" />

        <LinearLayout
        android:id="@+id/workout_editor_step_card"
        style="@style/RunnerUpCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="true"
        android:clipToOutline="true"
        android:minHeight="52dp"
        android:orientation="vertical">

        <LinearLayout
            style="@style/RunnerUpCard.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="52dp"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <view
                android:id="@+id/workout_step_button"
                class="org.runnerup.features.StepButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>
    </LinearLayout>
    </LinearLayout>
</LinearLayout>
