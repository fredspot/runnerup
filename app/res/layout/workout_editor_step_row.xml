<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/workout_editor_row_host"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="4dp"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/drag_handle"
        android:layout_width="44dp"
        android:layout_height="52dp"
        android:clickable="true"
        android:contentDescription="@string/Reorder_step"
        android:focusable="false"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        android:scaleType="center"
        android:src="@drawable/ic_drag_handle_24dp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/workout_editor_row_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="@string/Repeat_block"
            android:textAppearance="@style/ListCategoryHeading"
            android:textColor="@color/colorText"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/workout_editor_step_card"
            style="@style/RunnerUpCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:clipChildren="true"
            android:clipToOutline="true"
            android:descendantFocusability="blocksDescendants"
            android:focusable="true"
            android:minHeight="52dp"
            android:orientation="vertical">

            <LinearLayout
                style="@style/RunnerUpCard.Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:minHeight="52dp"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingTop="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="12dp">

                <View
                    android:id="@+id/repeat_accent"
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="10dp"
                    android:background="@color/stepRepeat"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/step_icon"
                    style="@style/RunnerUpCard.Content"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="@string/Edit_step" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/step_duration"
                        style="@style/RunnerUpCard.Content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/ListItem"
                        android:textColor="@color/colorText" />

                    <TextView
                        android:id="@+id/step_goal"
                        style="@style/RunnerUpCard.Content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textAppearance="@style/ListDescription"
                        android:textColor="@color/colorTextSecondary" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/step_chevron"
                    style="@style/RunnerUpCard.Content"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="8dp"
                    android:contentDescription="@string/Edit_step"
                    android:src="@drawable/ic_chevron_right_24dp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
