<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/monthly_comparison_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundPrimary">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/backgroundPrimary"
        android:elevation="0dp"
        app:titleTextColor="@color/colorText"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/monthly_comparison_empty_hint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/monthly_comparison_empty"
        android:textColor="@color/colorTextSecondary"
        android:textSize="14sp"
        android:gravity="center"
        android:visibility="gone"
        android:paddingTop="24dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ProgressBar
        android:id="@+id/monthly_comparison_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ScrollView
        android:id="@+id/monthly_comparison_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/monthly_comparison_metric_column"
                    android:textColor="@color/colorText"
                    android:textStyle="bold"
                    android:textSize="18sp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/this_month"
                    android:textColor="@color/colorAccent"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textAlignment="center"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/all_other_months"
                    android:textColor="@color/colorText"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textAlignment="center"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/monthly_comparison_best_column"
                    android:textColor="@color/colorText"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textAlignment="center"/>

            </LinearLayout>

            <!-- Avg Pace Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/avg_pace"
                    android:textColor="@color/colorText"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/this_month_avg_pace"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="--"
                    android:textColor="@color/colorAccent"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAlignment="center"/>

                <TextView
                    android:id="@+id/other_months_avg_pace"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="--"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="16sp"
                    android:textAlignment="center"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:paddingStart="2dp"
                    android:paddingEnd="4dp">
                    <TextView
                        android:id="@+id/best_month_avg_pace"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="16sp"
                        android:maxLines="1"
                        android:ellipsize="none"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="11sp"
                        app:autoSizeMaxTextSize="16sp"
                        android:textAlignment="center"/>
                    <TextView
                        android:id="@+id/best_month_avg_pace_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="9sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="7sp"
                        app:autoSizeMaxTextSize="9sp"
                        android:textAlignment="center"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Total Distance Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/total_distance"
                    android:textColor="@color/colorText"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/this_month_total_km"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="--"
                    android:textColor="@color/colorAccent"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textAlignment="center"/>

                <TextView
                    android:id="@+id/other_months_total_km"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="--"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="14sp"
                    android:textAlignment="center"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:paddingStart="2dp"
                    android:paddingEnd="4dp">
                    <TextView
                        android:id="@+id/best_month_total_km"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="14sp"
                        android:maxLines="1"
                        android:ellipsize="none"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="11sp"
                        app:autoSizeMaxTextSize="14sp"
                        android:textAlignment="center"/>
                    <TextView
                        android:id="@+id/best_month_total_km_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="9sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="7sp"
                        app:autoSizeMaxTextSize="9sp"
                        android:textAlignment="center"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Avg Distance Per Run Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/monthly_comparison_avg_distance"
                    android:textColor="@color/colorText"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/this_month_avg_distance_per_run"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="--"
                    android:textColor="@color/colorAccent"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAlignment="center"/>

                <TextView
                    android:id="@+id/other_months_avg_distance_per_run"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="--"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="16sp"
                    android:textAlignment="center"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:paddingStart="2dp"
                    android:paddingEnd="4dp">
                    <TextView
                        android:id="@+id/best_month_avg_distance_per_run"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="16sp"
                        android:maxLines="1"
                        android:ellipsize="none"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="11sp"
                        app:autoSizeMaxTextSize="16sp"
                        android:textAlignment="center"/>
                    <TextView
                        android:id="@+id/best_month_avg_distance_per_run_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="9sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="7sp"
                        app:autoSizeMaxTextSize="9sp"
                        android:textAlignment="center"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Avg BPM Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/average_bpm"
                    android:textColor="@color/colorText"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/this_month_avg_bpm"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="--"
                    android:textColor="@color/colorAccent"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAlignment="center"/>

                <TextView
                    android:id="@+id/other_months_avg_bpm"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="--"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="16sp"
                    android:textAlignment="center"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:paddingStart="2dp"
                    android:paddingEnd="4dp">
                    <TextView
                        android:id="@+id/best_month_avg_bpm"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="16sp"
                        android:maxLines="1"
                        android:ellipsize="none"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="11sp"
                        app:autoSizeMaxTextSize="16sp"
                        android:textAlignment="center"/>
                    <TextView
                        android:id="@+id/best_month_avg_bpm_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="9sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="7sp"
                        app:autoSizeMaxTextSize="9sp"
                        android:textAlignment="center"/>
                </LinearLayout>

            </LinearLayout>

            <!-- PB Count Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/personal_bests"
                    android:textColor="@color/colorText"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/this_month_pb_count"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="--"
                    android:textColor="@color/colorAccent"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAlignment="center"/>

                <TextView
                    android:id="@+id/other_months_pb_count"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="--"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="16sp"
                    android:textAlignment="center"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:paddingStart="2dp"
                    android:paddingEnd="4dp">
                    <TextView
                        android:id="@+id/best_month_pb_count"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="16sp"
                        android:maxLines="1"
                        android:ellipsize="none"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="11sp"
                        app:autoSizeMaxTextSize="16sp"
                        android:textAlignment="center"/>
                    <TextView
                        android:id="@+id/best_month_pb_count_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="9sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="7sp"
                        app:autoSizeMaxTextSize="9sp"
                        android:textAlignment="center"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Top 25 Count Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/monthly_comparison_top25_runs"
                    android:textColor="@color/colorText"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/this_month_top25_count"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="--"
                    android:textColor="@color/colorAccent"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAlignment="center"/>

                <TextView
                    android:id="@+id/other_months_top25_count"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="--"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="16sp"
                    android:textAlignment="center"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:paddingStart="2dp"
                    android:paddingEnd="4dp">
                    <TextView
                        android:id="@+id/best_month_top25_count"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="16sp"
                        android:maxLines="1"
                        android:ellipsize="none"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="11sp"
                        app:autoSizeMaxTextSize="16sp"
                        android:textAlignment="center"/>
                    <TextView
                        android:id="@+id/best_month_top25_count_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="9sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="7sp"
                        app:autoSizeMaxTextSize="9sp"
                        android:textAlignment="center"/>
                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp"
                android:text="@string/monthly_comparison_zone_section_title"
                android:textColor="@color/colorText"
                android:textSize="17sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textSize="12sp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/this_month"
                    android:textColor="@color/colorAccent"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textAlignment="center"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/monthly_comparison_zone_column_change"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textAlignment="center"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/monthly_comparison_best_column"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textAlignment="center"/>
            </LinearLayout>

            <!-- Z3 aerobic pace -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4"
                android:background="@drawable/card_background"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <TextView
                    android:id="@+id/metric_avg_pace_zone_3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/monthly_comparison_zone_pace_metric_unconfigured"
                    android:textColor="@color/colorText"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/this_month_avg_pace_zone_3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="--"
                    android:textColor="@color/colorAccent"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="none"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="11sp"
                    app:autoSizeMaxTextSize="16sp"
                    android:textAlignment="center"/>

                <TextView
                    android:id="@+id/other_months_avg_pace_zone_3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="--"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="16sp"
                    android:maxLines="1"
                    android:ellipsize="none"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="11sp"
                    app:autoSizeMaxTextSize="16sp"
                    android:textAlignment="center"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:paddingStart="2dp"
                    android:paddingEnd="4dp">
                    <TextView
                        android:id="@+id/best_month_avg_pace_zone_3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="16sp"
                        android:maxLines="1"
                        android:ellipsize="none"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="11sp"
                        app:autoSizeMaxTextSize="16sp"
                        android:textAlignment="center"/>
                    <TextView
                        android:id="@+id/best_month_avg_pace_zone_3_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="9sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="7sp"
                        app:autoSizeMaxTextSize="9sp"
                        android:textAlignment="center"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Easy pace Z1–Z2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4"
                android:background="@drawable/card_background"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <TextView
                    android:id="@+id/metric_easy_pace"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/monthly_comparison_zone_easy_metric"
                    android:textColor="@color/colorText"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/this_month_easy_pace"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="--"
                    android:textColor="@color/colorAccent"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="none"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="11sp"
                    app:autoSizeMaxTextSize="16sp"
                    android:textAlignment="center"/>

                <TextView
                    android:id="@+id/other_months_easy_pace"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="--"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="16sp"
                    android:maxLines="1"
                    android:ellipsize="none"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    app:autoSizeTextType="uniform"
                    app:autoSizeMinTextSize="11sp"
                    app:autoSizeMaxTextSize="16sp"
                    android:textAlignment="center"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:paddingStart="2dp"
                    android:paddingEnd="4dp">
                    <TextView
                        android:id="@+id/best_month_easy_pace"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="16sp"
                        android:maxLines="1"
                        android:ellipsize="none"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="11sp"
                        app:autoSizeMaxTextSize="16sp"
                        android:textAlignment="center"/>
                    <TextView
                        android:id="@+id/best_month_easy_pace_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="9sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="7sp"
                        app:autoSizeMaxTextSize="9sp"
                        android:textAlignment="center"/>
                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/monthly_comparison_zone_pace_footnote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:text="@string/monthly_comparison_zone_pace_footnote"
                android:textColor="@color/colorTextSecondary"
                android:textSize="12sp"
                android:lineSpacingExtra="2dp"/>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
