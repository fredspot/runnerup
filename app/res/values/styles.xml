<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="AppTheme" parent="Theme.AppCompat">
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="colorControlHighlight">@color/colorControlHighlight</item>
        <item name="android:defaultFocusHighlightEnabled">false</item>
        <!-- Flat ripple for generic rows; never use card drawables here (rectangular bounded ripple). -->
        <item name="selectableItemBackground">@drawable/ripple_borderless</item>
        <item name="android:selectableItemBackground">@drawable/ripple_borderless</item>
        <item name="selectableItemBackgroundBorderless">@drawable/ripple_borderless</item>
        <item name="android:selectableItemBackgroundBorderless">@drawable/ripple_borderless</item>
        <item name="preferenceTheme">@style/PreferenceThemeDark</item>
    </style>

    <!-- Static fill + full-card foreground ripple (combined ripple bg highlights only at touch point). -->
    <style name="RunnerUpCard">
        <item name="android:background">@drawable/card_background</item>
        <item name="android:foreground">@drawable/card_ripple_overlay</item>
        <item name="android:defaultFocusHighlightEnabled">false</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Padding belongs on this inner wrapper, not on the card root (keeps ripple full-card). -->
    <style name="RunnerUpCard.Body">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:clickable">false</item>
        <item name="android:focusable">false</item>
    </style>

    <!-- Children inside RunnerUpCard: no own ripple/background (avoids squares around text). -->
    <style name="RunnerUpCard.Content">
        <item name="android:background">@null</item>
        <item name="android:duplicateParentState">false</item>
        <item name="android:clickable">false</item>
        <item name="android:focusable">false</item>
        <item name="android:defaultFocusHighlightEnabled">false</item>
        <item name="android:textColorHighlight">@android:color/transparent</item>
    </style>

    <!-- Dark theme for preferences: flat rows, no card fill (see preference_runnerup_row.xml) -->
    <style name="PreferenceThemeDark" parent="@style/PreferenceThemeOverlay">
        <item name="android:textColorPrimary">@color/colorText</item>
        <item name="android:textColorSecondary">@color/colorTextSecondary</item>
        <item name="android:background">@color/backgroundPrimary</item>
        <item name="android:textColor">@color/colorText</item>
        <item name="colorControlNormal">@color/colorTextSecondary</item>
        <item name="colorControlActivated">@color/colorAccent</item>
        <item name="android:selectableItemBackground">@drawable/ripple_borderless</item>
        <item name="selectableItemBackground">@drawable/ripple_borderless</item>
        <item name="preferenceStyle">@style/Preference.RunnerUp</item>
        <item name="checkBoxPreferenceStyle">@style/Preference.RunnerUp</item>
        <item name="switchPreferenceStyle">@style/Preference.RunnerUp</item>
        <item name="switchPreferenceCompatStyle">@style/Preference.RunnerUp</item>
        <item name="dialogPreferenceStyle">@style/Preference.RunnerUp</item>
        <item name="editTextPreferenceStyle">@style/Preference.RunnerUp</item>
        <item name="dropdownPreferenceStyle">@style/Preference.RunnerUp</item>
    </style>

    <style name="Preference.RunnerUp" parent="@style/Preference.Material">
        <item name="android:layout">@layout/preference_runnerup_row</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="AppTheme">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
    </style>

    <style name="MainLayoutTheme" parent="AppTheme.NoActionBar">
        <item name="android:tabWidgetStyle">@style/BottomNavigationTabWidget</item>
    </style>

    <style name="ButtonText" parent="Widget.AppCompat.Button">
        <item name="android:textColor">@color/btn_text_color</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Match Run tab Start GPS (rounded blue, white bold label). -->
    <style name="RunPrimaryButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/button_start_gps</item>
        <item name="android:textColor">@color/button_text_colors</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:elevation">4dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="RunSecondaryButton" parent="RunPrimaryButton">
        <item name="android:background">@drawable/button_scan_grey</item>
    </style>

    <style name="RunHeader" parent="AppTheme">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">@color/colorTextSecondary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="RunInfo" parent="AppTheme">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">end</item>
        <item name="android:textColor">@color/colorText</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="BottomNavigationTabWidget" parent="android:Widget.TabWidget">
        <item name="android:ellipsize">marquee</item>
        <item name="android:singleLine">true</item>
        <item name="android:tabStripEnabled">false</item>
        <item name="divider">@null</item>
        <item name="android:gravity">fill_horizontal|center_vertical</item>
    </style>

    <style name="BottomNavigationTabText" tools:ignore="UnusedResources">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/bottom_tabs</item>
    </style>

    <!-- Detail / Start inner tabs (replaces TabHost + Holo indicators) -->
    <style name="InnerTabLayout" parent="Widget.Design.TabLayout">
        <item name="tabMode">fixed</item>
        <item name="tabGravity">fill</item>
        <item name="tabIndicatorHeight">0dp</item>
        <item name="tabRippleColor">@null</item>
        <item name="tabTextAppearance">@style/InnerTabText</item>
    </style>

    <style name="InnerTabText" parent="TextAppearance.AppCompat.Medium">
        <item name="android:textAllCaps">false</item>
        <item name="textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/colorText</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:singleLine">true</item>
    </style>

    <style name="AccountListText" parent="RunnerUpCard.Content">
        <item name="android:textSize">18sp</item>
    </style>

    <style name="AppBarStatisticsText">
        <item name="fontFamily" tools:ignore="NewApi">@string/fontFamily_medium</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="ListItem">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/colorText</item>
    </style>

    <style name="ListDescription">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/colorTextSecondary</item>
    </style>

    <style name="ListCategoryHeading">
        <item name="fontFamily" tools:ignore="NewApi">@string/fontFamily_medium</item>
        <item name="android:textColor">@color/colorAccent</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="StatusText">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/colorText</item>
    </style>
    
    <!-- Modern card style -->
    <style name="CardTitle">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/colorTextSecondary</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <style name="CardValue">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/colorText</item>
    </style>
    
    <!-- Modern AlertDialog theme -->
    <style name="AlertDialogTheme" parent="Theme.AppCompat.Dialog.Alert">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:textColorPrimary">@color/colorText</item>
        <item name="android:textColorSecondary">@color/colorTextSecondary</item>
        <item name="android:background">@color/backgroundCard</item>
        <item name="android:windowBackground">@drawable/dialog_background_rounded</item>
        <item name="buttonBarButtonStyle">@style/AlertDialogButton</item>
    </style>

    <style name="AlertDialogButton" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">@color/colorAccent</item>
    </style>

</resources>
